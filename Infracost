name: Infracost

on:
  pull_request:

permissions:
  contents: read
  pull-requests: write

jobs:
  infracost:
    name: Infracost cost estimate
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 2

      - uses: infracost/infracost-github-action@v2
        with:
          path: .
          api-key: ${{ secrets.INFRACOST_API_KEY }}
          behavior: update
